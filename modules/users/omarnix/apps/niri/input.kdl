input {
    keyboard {
        repeat-rate 35
        repeat-delay 200
        xkb {
            layout "us,ara"
            options "grp:win_space_toggle,compose:ralt"
        }
        numlock
    }
    touchpad {
        tap
        natural-scroll
    }
    mouse {
    }
    trackpoint {
    }
    focus-follows-mouse max-scroll-amount="0%"
}
