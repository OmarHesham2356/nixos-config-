#!/usr/bin/env bash
# Generate tmux theme from pywal colors
set -euo pipefail

WAL_JSON="$HOME/.cache/wal/colors.json"
THEME="$HOME/.config/tmux/theme.conf"

if [[ ! -f "$WAL_JSON" ]]; then
  exit 0
fi

python3 -c "
import json
with open('$WAL_JSON') as f:
    c = json.load(f)
s = c.get('special', {})
a = c.get('colors', {})

bg = s.get('background', '#1e1e2e')
fg = s.get('foreground', '#cdd6f4')
c0 = a.get('color0', '#1e1e2e')
c1 = a.get('color1', '#f38ba8')
c2 = a.get('color2', '#a6e3a1')
c3 = a.get('color3', '#f9e2af')
c4 = a.get('color4', '#89b4fa')
c5 = a.get('color5', '#f5c2e7')
c6 = a.get('color6', '#94e2d5')
c8 = a.get('color8', '#585b70')
c15 = a.get('color15', '#a6adc8')

theme = f'''# Pywal tmux theme
set -g @wal_theme '1'

# Status bar
set -g status-style \"bg={bg},fg={fg}\"
set -g status-position bottom
set -g status-justify left
set -g status-left-length 40
set -g status-right-length 60

# Left status
set -g status-left \"#[bg={c4},fg={bg},bold] #S #[bg={bg},fg={c4}] \"

# Right status
set -g status-right \"#[fg={c8}]%H:%M #[fg={c8}]│ #[fg={c15}]%Y-%m-%d \"

# Window status
setw -g window-status-format \"#[fg={c8}] #I:#W \"
setw -g window-status-current-format \"#[bg={c4},fg={bg},bold] #I:#W \"
setw -g window-status-separator \"\"

# Pane borders
set -g pane-border-style \"fg={c8}\"
set -g pane-active-border-style \"fg={c4}\"

# Messages
set -g message-style \"bg={c4},fg={bg}\"

# Clock
setw -g clock-mode-colour \"{c4}\"
setw -g clock-mode-style 24

# Bell
setw -g window-status-bell-style \"bg={c1},fg={bg},bold\"
'''

with open('$THEME', 'w') as f:
    f.write(theme)
" 2>&1 || true
