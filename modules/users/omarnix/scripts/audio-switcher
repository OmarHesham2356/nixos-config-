#!/usr/bin/env bash
# Audio output switcher using rofi
sinks=$(pactl list sinks short | awk '{print $2}')
current=$(pactl get-default-sink)

rofi_lines=""
for s in $sinks; do
  desc=$(pactl list sinks | grep -A 20 "Name: $s" | grep "Description:" | sed 's/.*Description: //')
  if [ "$s" = "$current" ]; then
    rofi_lines="$rofi_lines\n  $desc  (current)"
  else
    rofi_lines="$rofi_lines\n  $desc"
  fi
done

selected=$(printf '%b' "$rofi_lines" | sed '1d' | rofi -dmenu -p " Audio Output " -i)
if [ -z "$selected" ]; then
  exit
fi

chosen_desc=$(echo "$selected" | sed 's/  //' | sed 's/  (current)//')
for s in $sinks; do
  desc=$(pactl list sinks | grep -A 20 "Name: $s" | grep "Description:" | sed 's/.*Description: //')
  if [ "$desc" = "$chosen_desc" ]; then
    pactl set-default-sink "$s"
    for i in $(pactl list sink-inputs short | awk '{print $1}'); do
      pactl move-sink-input "$i" "$s" 2>/dev/null
    done
    notify-send "Audio" "Switched to $desc"
    exit 0
  fi
done

notify-send "Audio" "Error: no matching sink" -u critical
