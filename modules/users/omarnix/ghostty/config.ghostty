# DankMaterialShell Theme
theme = dankcolors

# --- Appearance ---
font-size = 12
window-decoration = false
window-padding-x = 12
window-padding-y = 12
background-opacity = 0.7

# --- Cursor ---
shell-integration = detect
shell-integration-features = cursor,sudo,title
cursor-style = block
cursor-style-blink = false  

# --- System ---
gtk-titlebar = false
gtk-single-instance = true
